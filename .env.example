# 钉钉机器人配置（在钉钉开放平台获取）
# 应用的 AppKey（AK）
DINGTALK_APP_KEY=your_app_key_here

# 应用的 AppSecret（SK）
DINGTALK_APP_SECRET=your_app_secret_here

# 安全设置：允许操作的钉钉用户 ID，多个用逗号分隔（留空则不限制，不建议）
# 在钉钉开放平台可查看用户的 unionId 或 staffId
ALLOWED_USER_IDS=

# PTY 终端会话超时时间（分钟），超时后自动关闭
TERMINAL_TIMEOUT_MIN=30

# PTY 输出缓冲时间（毫秒），收集输出后一次性发送，减少消息频率
OUTPUT_BUFFER_MS=300
